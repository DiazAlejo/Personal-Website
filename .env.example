# =============================================================================
# Environment Variables
# Copy to .env.local for local development.
# Configure in Vercel Project Settings → Environment Variables for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

# Canonical public URL used for SEO metadata, sitemap, and Open Graph.
# Production: your Vercel URL (e.g. https://personal-website-xxx.vercel.app)
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Analytics (PostHog) — optional, privacy-conscious explicit events only
# -----------------------------------------------------------------------------

# Set to "false" to disable analytics even when a key is present.
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# PostHog project API key (client-side, safe to expose).
# Leave empty to disable analytics in development.
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingest host. US default: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Monitoring (Sentry) — optional client-side error tracking
# -----------------------------------------------------------------------------

# Sentry DSN for browser error reporting.
# Use NEXT_PUBLIC_SENTRY_DSN for Next.js client bundles.
NEXT_PUBLIC_SENTRY_DSN=

# Server-side alias (optional). Used as fallback when NEXT_PUBLIC_SENTRY_DSN is unset.
SENTRY_DSN=
